            }
          ]
        },
        "error": {
          "status": 403,
          "body": {
            "detail": "You do not have permission to perform this action."
          }
        }
      }
    },
    {
      "title": "Admin - Delete Appointment",
      "url": "/admin/appointments/{id}/",
      "method": "DELETE",
      "permissions": ["IsAdmin"],
      "description": "Delete an appointment from the system",
      "requestBody": null,
      "responses": {
        "success": {
          "status": 204,
          "body": null
        },
        "error": {
          "status": 404,
          "body": {
            "detail": "Not found."
          }
        }
      }
    },
    {
      "title": "Admin - Swap Admin Account (Request OTPs)",
      "url": "/admin/swap-admin/",
      "method": "POST",
      "permissions": ["IsAdmin"],
      "description": "Step 1: Request OTPs for changing admin email. OTPs will be printed to console.",
      "requestBody": {
        "step": "request",
        "new_email": "newadmin@example.com"
      },
      "responses": {
        "success": {
          "status": 200,
          "body": {
            "message": "OTPs generated. Check console.",
            "new_email": "newadmin@example.com",
            "new_otp_for_verification": "654321"
          }
        },
        "error": {
          "status": 400,
          "body": {
            "error": "Email already exists."
          }
        }
      }
    },
    {
      "title": "Admin - Swap Admin Account (Verify OTPs)",
      "url": "/admin/swap-admin/",
      "method": "POST",
      "permissions": ["IsAdmin"],
      "description": "Step 2: Verify OTPs and complete admin email swap",
      "requestBody": {
        "step": "verify",
        "new_email": "newadmin@example.com",
        "current_otp": "123456",
        "new_otp": "654321"
      },
      "responses": {
        "success": {
          "status": 200,
          "body": {
            "message": "Admin email updated successfully.",
            "new_email": "newadmin@example.com"
          }
        },
        "error": {
          "status": 401,
          "body": {
            "error": "Invalid or expired current admin OTP."
          }
        }
      }
    }
  ]
}
